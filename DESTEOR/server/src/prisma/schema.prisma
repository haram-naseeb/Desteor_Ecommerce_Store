// DESTEOR — Prisma Schema
//
// Sprint 1: datasource and generator configuration only.
// No models are defined yet — application models will be introduced
// in future sprints as each feature is designed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id                       String    @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String    @unique
  password                 String
  role                     Role      @default(CUSTOMER)
  phone                    String?
  refreshTokenHash         String?
  resetPasswordTokenHash   String?
  resetPasswordTokenExpiry DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([email])
  @@index([resetPasswordTokenHash])
}
